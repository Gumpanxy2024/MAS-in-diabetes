# ============================================================
# CDM System .gitignore
# ============================================================

# ─── 环境变量 & 密钥（绝对不能提交）───
.env
*.env.local

# ─── Python ───
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ─── Django ───
cdm_system/db.sqlite3
cdm_system/media/
cdm_system/logs/
cdm_system/static/collected/

# ─── IDE ───
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/

# ─── OS ───
.DS_Store
Thumbs.db
desktop.ini

# ─── LaTeX 编译产物（如在本地编译）───
thesis/*.aux
thesis/*.log
thesis/*.out
thesis/*.toc
thesis/*.lof
thesis/*.lot
thesis/*.bbl
thesis/*.blg
thesis/*.synctex.gz
thesis/*.fdb_latexmk
thesis/*.fls
thesis/*.xdv

# ─── ChromaDB 向量库（可重建）───
cdm_system/chroma_db/

# ─── 临时文件 & 参考资料 ───
_ref_thesis.txt
*.tmp
210750110*.docx

# ─── 知识库原始文件（体积大，不提交）───
cdm_system/knowledge_base/raw/*.pdf
cdm_system/knowledge_base/raw/*.docx
